#!/usr/bin/env bash

echo "🔍 Running Scrutineer PR Review..."

# scrutineer's --diff flag reviews the diff between a target ref and whatever
# is currently checked out as HEAD — it has no way to target an arbitrary
# pushed SHA (confirmed in its git-diff.js: it always runs `<target>...HEAD`).
# That's fine for the common case (pushing the branch you have checked out),
# but silently wrong if you push a ref that isn't your current HEAD, e.g.
# `git push origin feature:feature` while sitting on main — the hook would
# review "main vs origin/main" (empty) while feature's real content ships
# completely unreviewed. So we still read pre-push's stdin, not to hand-roll
# the diff ourselves anymore, but just to make sure every ref being pushed
# actually matches HEAD before trusting --diff to review it. Anything that
# doesn't match aborts the push rather than silently reviewing the wrong
# thing. Deletions (zero_sha) are skipped — there's nothing to review.
zero_sha="0000000000000000000000000000000000000000"
head_sha=$(git rev-parse HEAD)
review_timeout="${SCRUTINEER_TIMEOUT:-180}"
mismatched_ref=""
has_reviewable_ref=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_sha" ] || [ "$local_sha" = "$zero_sha" ] && continue

  if [ "$local_sha" != "$head_sha" ]; then
    mismatched_ref="$local_ref"
    continue
  fi

  has_reviewable_ref=1
done

if [ -n "$mismatched_ref" ]; then
  echo "❌ pre-push: aborting — '$mismatched_ref' points to a commit other than the currently checked-out HEAD, and scrutineer's --diff can only review HEAD. Check out '$mismatched_ref' and push again, or use 'git push --no-verify' if you are certain no review is needed." >&2
  exit 1
fi

if [ "$has_reviewable_ref" -eq 0 ]; then
  echo "✅ No non-deletion refs to review. Pushing..."
  exit 0
fi

timeout "$review_timeout" pnpm run review:local
RESULT=$?

if [ "$RESULT" -eq 124 ]; then
  echo "❌ Scrutineer review timed out after ${review_timeout}s (check that Ollama is reachable and the model is pulled)." >&2
  exit 1
fi

if [ "$RESULT" -ne 0 ]; then
  echo "❌ Scrutineer found issues. Push aborted."
  exit 1
fi

echo "✅ Scrutineer review passed. Pushing..."
exit 0
